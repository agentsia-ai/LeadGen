# ============================================================
# LeadGen / Legion — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Lead Sources ---
# Apollo.io — https://developer.apollo.io
APOLLO_API_KEY=

# Hunter.io — https://hunter.io/api
HUNTER_API_KEY=

# Clearbit — https://clearbit.com/docs
CLEARBIT_API_KEY=

# --- Outreach ---
# Option A: SMTP (Gmail, Outlook, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Option B: SendGrid
SENDGRID_API_KEY=

# --- LinkedIn (optional, use carefully) ---
LINKEDIN_ACCESS_TOKEN=

# --- Database ---
# Leave blank to use local SQLite (default)
# Set to a Supabase connection string for cloud mode
DATABASE_URL=

# --- App Settings ---
# Path to your client config file
CONFIG_PATH=config.yaml

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# MCP server port (for Claude Desktop integration)
MCP_PORT=8765
